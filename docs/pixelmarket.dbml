// PixelMarket — Schéma de base de données
// TPI CFC Informaticien — Nico Mengisen
// Compatible avec dbdiagram.io

// ─────────────────────────────────────────
// NOTES SÉCURITÉ
// • password_hash : bcrypt produit 60 chars, varchar(60) suffit techniquement
//   mais on prend 72 pour absorber un éventuel changement d'algo (argon2 = 95 chars)
// • email : RFC 5321 limite à 254 chars max
// • reset_token : secrets.token_urlsafe(48) = 64 chars → varchar(100) avec marge
// • file_path / preview_path : 512 chars couvre les paths longs avec sous-dossiers
// • price / amount : DECIMAL(10,2) évite les erreurs d'arrondi du float (ex. 9.99 ≠ 9.990000001)
// • role : enum string contrôlé applicativement, pas de valeur libre possible
// ─────────────────────────────────────────

Table users {
  id              integer       [pk, increment]
  username        varchar(80)   [unique, not null,  note: "Affiché publiquement"]
  email           varchar(254)  [unique, not null,  note: "RFC 5321 — max 254 chars"]
  password_hash   varchar(72)   [not null,          note: "bcrypt hash — jamais le mot de passe en clair"]
  role            varchar(10)   [not null, default: 'user', note: "user | artist | admin"]
  is_active       boolean       [not null, default: true,   note: "Soft delete — ne pas supprimer physiquement"]
  reset_token     varchar(100)  [null,     note: "Token unique généré via secrets.token_urlsafe(48)"]
  reset_expires   timestamp     [null,     note: "Expiration du token — 1h recommandé"]
  created_at      timestamp     [not null, default: `now()`]

  indexes {
    email         [unique, name: 'idx_users_email']
    username      [unique, name: 'idx_users_username']
    role                  [name: 'idx_users_role']
    reset_token   [unique, name: 'idx_users_reset_token']
  }

  note: "Un seul modèle User pour les 3 rôles — géré par le champ role"
}

Table artworks {
  id              integer        [pk, increment]
  name            varchar(200)   [not null]
  description     text           [null]
  price           decimal(10,2)  [not null,         note: "DECIMAL évite les erreurs float — ex. 9.99"]
  artist_id       integer        [not null, ref: > users.id, note: "Clé étrangère vers l'artiste (role='artist')"]
  preview_path    varchar(512)   [null,             note: "Image affichée sur le site (peut être watermarkée)"]
  file_path       varchar(512)   [null,             note: "Fichier haute qualité envoyé par mail après achat"]
  category        varchar(50)    [null,             note: "photo | video | music | poster | image — pour les filtres"]
  is_sold         boolean        [not null, default: false, note: "true = retiré du catalogue automatiquement"]
  created_at      timestamp      [not null, default: `now()`]

  indexes {
    artist_id             [name: 'idx_artworks_artist']
    is_sold               [name: 'idx_artworks_sold']
    category              [name: 'idx_artworks_category']
    (artist_id, is_sold)  [name: 'idx_artworks_artist_sold']
  }

  note: "preview_path ≠ file_path : sécurise le fichier original jusqu'au paiement"
}

Table orders {
  id              integer        [pk, increment]
  buyer_id        integer        [not null, ref: > users.id]
  artwork_id      integer        [not null, ref: > artworks.id]
  amount          decimal(10,2)  [not null,  note: "Snapshot du prix au moment de l'achat"]
  email_sent      boolean        [not null, default: false, note: "True une fois le fichier envoyé par mail"]
  created_at      timestamp      [not null, default: `now()`]

  indexes {
    buyer_id              [name: 'idx_orders_buyer']
    artwork_id            [name: 'idx_orders_artwork']
    (buyer_id, created_at) [name: 'idx_orders_history']
  }

  note: "amount snapshote le prix — si l'artiste modifie le prix plus tard, l'historique reste cohérent"
}

Table newsletter {
  id              integer        [pk, increment]
  email           varchar(254)   [unique, not null, note: "RFC 5321"]
  is_active       boolean        [not null, default: true, note: "Désabonnement = false, pas de suppression"]
  created_at      timestamp      [not null, default: `now()`]

  indexes {
    email         [unique, name: 'idx_newsletter_email']
    is_active             [name: 'idx_newsletter_active']
  }
}
